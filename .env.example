# ── LLM Configuration ──────────────────────────────────────────
# Required: Your OpenAI API key (or compatible provider key)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Custom API endpoint (e.g., local proxy, Ollama, Featherless.ai)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=http://localhost:11434/v1

# Optional: Model name (defaults to provider's default)
# LLM_MODEL_NAME=gpt-4o-mini

# Optional: LLM temperature (0.0–2.0, lower = more deterministic)
# LLM_TEMPERATURE=0.2

# ── Redis ──────────────────────────────────────────────────────
# Redis host and port for the ARQ task queue
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ── Database ───────────────────────────────────────────────────
# SQLite (default) — suitable for development and single-user
# DATABASE_URL=sqlite+aiosqlite:///./proposal_agent.db
#
# PostgreSQL (production) — swap to asyncpg driver
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/proposals
